{
  "name": "clover",
  "version": "1.0.0",
  "description": "Clover CRM",
  "main": "main.js",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "dev:desktop": "electron .",
    "build:windows": "next build && electron-builder --win",
    "build:mac": "next build && electron-builder --mac"
  },
  "build": {
    "asar": false,
    "appId": "com.epicmanagement.crm",
    "productName": "CLOVER",
    "directories": {
      "output": "dist-desktop"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "mac": {
      "icon": "build/icon.png",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "files": [
      "main.js",
      "package.json",
      ".next/standalone/**/*"
    ],
    "extraResources": [
      {
        "from": ".next/static",
        "to": "app/.next/standalone/.next/static"
      },
      {
        "from": "public",
        "to": "app/.next/standalone/public"
      }
    ]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1079.0",
    "@aws-sdk/s3-request-presigner": "^3.1079.0",
    "@google/generative-ai": "^0.24.1",
    "@paypal/react-paypal-js": "^10.0.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "@tiptap/extension-color": "^3.23.1",
    "@tiptap/extension-text-align": "^3.23.1",
    "@tiptap/extension-text-style": "^3.23.1",
    "@tiptap/extension-underline": "^3.23.1",
    "@tiptap/pm": "^3.23.1",
    "@tiptap/react": "^3.23.1",
    "@tiptap/starter-kit": "^3.23.1",
    "@types/nodemailer": "^8.0.0",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.40.0",
    "googleapis": "^171.4.0",
    "jszip": "^3.10.1",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "nodemailer": "^8.0.7",
    "react": "19.2.4",
    "react-datepicker": "^9.1.0",
    "react-dom": "19.2.4",
    "react-player": "^3.4.0",
    "recharts": "^3.8.1",
    "signature_pad": "^5.1.3",
    "twilio": "^6.0.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-datepicker": "^6.2.0",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "puppeteer": "^25.3.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.5"
  }
}
